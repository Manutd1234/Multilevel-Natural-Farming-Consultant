# KisaanVaani environment variables
# Copy this file to .env (local) or set these in Vercel → Settings → Environment Variables.
# .env is gitignored — never commit real keys.

# LLM for the advisor + disease answers. The app prefers OpenAI (ChatGPT) when
# OPENAI_API_KEY is set, and falls back to Gemini, then to the local KB.
# Set EITHER OpenAI (recommended — paid credits, reliable) OR Gemini (free tier).

# --- OpenAI / ChatGPT (primary) ---
# Key: https://platform.openai.com/api-keys  (starts with sk-...)
OPENAI_API_KEY=
# Model name (default: gpt-4o-mini). gpt-4o also works and is stronger on vision.
# OPENAI_MODEL=gpt-4o-mini
# Note: CHATGPT_MODEL is also accepted as the model-name variable.

# --- Gemini (fallback) ---
# Free key: https://aistudio.google.com  (Get API key)
GEMINI_API_KEY=

# OPTIONAL — everything below has a graceful fallback.

# Override the Gemini model (default: gemini-2.5-flash).
# Note: gemini-2.0-flash currently has zero free-tier quota on many keys.
# GEMINI_MODEL=gemini-2.5-flash

# Live mandi prices from data.gov.in. A public sample key is bundled as default,
# but it is shared/rate-limited and caps results. Register for your own free key
# at https://data.gov.in (My Account → API key) for higher limits.
# DATA_GOV_API_KEY=
# DATA_GOV_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

# Server-side Whisper STT (NOT needed — the browser Web Speech API handles voice).
# Only set this if you want a server fallback for browsers without Web Speech API.
# HF_TOKEN=
# WHISPER_MODEL=openai/whisper-small
# WHISPER_ENDPOINT_URL=
